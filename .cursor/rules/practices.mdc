### Generic Type Naming

Use descriptive single-letter names for generic types:

```typescript
// ✅ Good: Clear generic type naming
interface ApiResponse<TData> {
  success: boolean;
  data: TData;
  error?: string;
}

interface Repository<TEntity, TId> {
  findById(id: TId): Promise<Result<TEntity, NotFoundError>>;
  save(entity: TEntity): Promise<Result<TEntity, DatabaseError>>;
}

function processItems<TItem, TResult>(
  items: TItem[],
  processor: (item: TItem) => TResult
): TResult[] {
  return items.map(processor);
}

// ❌ Bad: Unclear generic type naming
interface ApiResponse<T> {
  success: boolean;
  data: T;
  error?: string;
}

interface Repository<E, I> {
  findById(id: I): Promise<Result<E, NotFoundError>>;
  save(entity: E): Promise<Result<E, DatabaseError>>;
}

function processItems<I, R>(items: I[], processor: (item: I) => R): R[] {
  return items.map(processor);
}
```

