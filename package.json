{
  "name": "nextjs-elysia-template",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "check": "biome check --write .",
    "ruler:apply": "bunx @intellectronica/ruler@latest apply --local-only",
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:native": "turbo -F native dev",
    "dev:web": "turbo -F @workspace/web dev",
    "dev:server": "turbo -F @workspace/server dev",
    "db:push": "turbo -F @workspace/server db:push",
    "db:studio": "turbo -F @workspace/server db:studio",
    "db:generate": "turbo -F @workspace/server db:generate",
    "db:migrate": "turbo -F @workspace/server db:migrate"
  },
  "dependencies": {},
  "devDependencies": {
    "turbo": "^2.5.8",
    "@biomejs/biome": "^2.2.5",
    "ultracite": "^5.6.2"
  },
  "packageManager": "bun@1.2.12"
}
